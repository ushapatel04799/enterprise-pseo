<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}" />
    <link rel="canonical" href="{{ canonicalUrl }}" />

    <!-- Modern Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet" />

    <!-- Inline Styles (Optimized for FCP and LCP) -->
    <style>
      :root {
        --primary: {{ theme.primaryColor | default('#0c4a6e') }};
        --secondary: {{ theme.secondaryColor | default('#f59e0b') }};
        --text: #0f172a;
        --bg-light: #f8fafc;
        --font: 'Outfit', sans-serif;
        --card-bg: #ffffff;
        --border: rgba(0, 0, 0, 0.06);
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: var(--font);
        color: var(--text);
        background-color: var(--bg-light);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      header {
        background-color: #ffffff;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 1rem 2rem;
      }
      .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .brand {
        font-weight: 800;
        font-size: 1.5rem;
        color: var(--primary);
        text-decoration: none;
      }
      .phone-cta {
        background-color: var(--secondary);
        color: #ffffff;
        padding: 0.6rem 1.5rem;
        border-radius: 9999px;
        text-decoration: none;
        font-weight: 600;
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .phone-cta:hover {
        transform: scale(1.05);
      }
      main {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1.5rem;
      }

      /* Hero Section Component */
      .hero-section {
        background: linear-gradient(135deg, var(--primary) 0%, #1e293b 100%);
        color: #ffffff;
        padding: 4rem 2rem;
        border-radius: 1rem;
        text-align: center;
        margin-bottom: 2rem;
      }
      .hero-section h1 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        line-height: 1.2;
      }
      .hero-section p {
        font-size: 1.2rem;
        color: #cbd5e1;
        margin-bottom: 2rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
      }
      .cta-button {
        display: inline-block;
        background-color: var(--secondary);
        color: #ffffff;
        padding: 0.8rem 2rem;
        border-radius: 9999px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1rem;
        transition: all 0.2s ease;
      }
      .cta-button:hover {
        transform: scale(1.03);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
      }

      /* Content Blocks */
      .local-intro-section, .service-details-section, .nearby-section, .faqs-section, .widgets-section {
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 1rem;
        padding: 2rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
      }
      h2 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: var(--primary);
      }
      .highlights-list {
        list-style-type: none;
      }
      .highlights-list li {
        position: relative;
        padding-left: 1.75rem;
        margin-bottom: 0.75rem;
      }
      .highlights-list li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--secondary);
        font-weight: 900;
      }

      /* FAQs */
      .faq-item {
        border-bottom: 1px solid var(--border);
        padding: 1rem 0;
      }
      .faq-item:last-child {
        border-bottom: none;
      }
      .faq-question {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
      }
      .faq-answer {
        color: #475569;
      }

      /* Widgets Grid */
      .widgets-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
      }
      .widget-weather {
        background-color: var(--bg-light);
        padding: 1.5rem;
        border-radius: 0.75rem;
      }
      .widget-maps iframe {
        width: 100%;
        height: 250px;
        border: none;
        border-radius: 0.75rem;
      }

      /* Footer */
      footer {
        background-color: #0f172a;
        color: #f3f4f6;
        padding: 4rem 2rem;
        margin-top: 4rem;
        border-top: 4px solid var(--secondary);
      }
      .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
      }
      .footer-section h3 {
        color: #ffffff;
        margin-bottom: 1.25rem;
        font-weight: 600;
      }
      .footer-links a {
        color: #cbd5e1;
        text-decoration: none;
        display: block;
        margin-bottom: 0.75rem;
      }
      .footer-links a:hover {
        color: #ffffff;
      }
      .copyright {
        text-align: center;
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.1);
        color: #94a3b8;
        font-size: 0.875rem;
      }
    </style>

    <!-- Schema Structured Data Injection -->
    {% if schemas %}
    <script type="application/ld+json">
      {{ schemas | safe }}
    </script>
    {% endif %}
  </head>
  <body>
    <header>
      <div class="nav-container">
        <a href="/" class="brand">{{ business.name }}</a>
        <a href="tel:{{ business.phone }}" class="phone-cta">Call {{ business.phone }}</a>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer>
      <div class="footer-container">
        <div class="footer-section">
          <h3>{{ business.name }}</h3>
          <p>{{ business.legalName }}</p>
          <p>License: {{ business.licenseNumber }}</p>
        </div>
        <div class="footer-section">
          <h3>Our Headquarters</h3>
          <p>{{ business.address.streetAddress }}</p>
          <p>{{ business.address.addressLocality }}, {{ business.address.addressRegion }} {{ business.address.postalCode }}</p>
        </div>
        <div class="footer-section footer-links">
          <h3>Legal</h3>
          <a href="{{ business.privacyPolicyUrl }}">Privacy Policy</a>
          <a href="{{ business.termsUrl }}">Terms & Conditions</a>
        </div>
      </div>
      <div class="copyright">
        <p>&copy; {{ copyrightYear }} {{ business.name }}. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
