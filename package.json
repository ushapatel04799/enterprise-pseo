{
  "name": "enterprise-pseo",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise programmatic SEO platform.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "eleventy --serve",
    "build": "eleventy",
    "test": "node --test tests/unit/*.test.js",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('output', { recursive: true, force: true });\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@tailwindcss/postcss": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.17",
    "tailwindcss": "^4.3.2"
  }
}
